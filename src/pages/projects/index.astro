---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

const projects = await getCollection("projects");
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Projects" pageDesc="Things I have built or am building.">
    {
      projects.length === 0 ? (
        <p class="mt-8 opacity-60">No projects yet. Check back soon.</p>
      ) : (
        <div class="grid gap-6">
          {projects.map(project => (
            <div class="rounded-lg border border-border p-5">
              <h2 class="text-lg font-semibold text-foreground">
                {project.data.title}
              </h2>
              <p class="mt-1 text-sm opacity-80">{project.data.description}</p>
              {project.data.stack.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {project.data.stack.map(tech => (
                    <span class="rounded bg-muted px-2 py-0.5 text-xs">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
              <div class="mt-3 flex gap-4 text-sm">
                {project.data.repo && (
                  <a
                    href={project.data.repo}
                    class="text-accent decoration-dashed underline-offset-4 hover:underline"
                  >
                    Source
                  </a>
                )}
                {project.data.live && (
                  <a
                    href={project.data.live}
                    class="text-accent decoration-dashed underline-offset-4 hover:underline"
                  >
                    Live
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }
  </Main>
  <Footer />
</Layout>
